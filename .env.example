VITE_API_BASE_URL=http://localhost:4000
VITE_TUNNEL_MANAGER_URL=http://localhost:4100

# Tunnel config
REMOTE_TUNNEL_HOST=c03
REMOTE_TUNNEL_USER=matbwyler@172.16.46.6
REMOTE_TUNNEL_PORT=4000
REMOTE_TUNNEL_TARGET_HOST=

# Optional: define the SSH gateway separately instead of embedding it in REMOTE_TUNNEL_USER
# REMOTE_TUNNEL_GATEWAY=172.16.46.6

# Optional: full SSH destination override (highest priority), e.g. matbwyler@172.16.46.6
# REMOTE_TUNNEL_DESTINATION=

# Local forward config
LOCAL_TUNNEL_BIND=127.0.0.1

# Optional SSH overrides
# REMOTE_TUNNEL_IDENTITY_FILE=C:/Users/you/.ssh/id_rsa
# REMOTE_TUNNEL_SSH_CONFIG_FILE=C:/Users/you/.ssh/config
# REMOTE_TUNNEL_EXTRA_ARGS=-o ServerAliveInterval=30

# Tunnel manager API port
TUNNEL_MANAGER_PORT=4100